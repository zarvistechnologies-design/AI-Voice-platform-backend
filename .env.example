PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/ai-voice-platform
DNS_SERVERS=1.1.1.1,8.8.8.8
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# LiveKit credentials must only exist on the backend/agent worker.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=voice-platform-agent
LIVEKIT_SIP_INBOUND_TRUNK_ID=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
# Outbound caller ID comes from the Vobiz number imported for the selected agent.

# Customer provider tokens are entered in the dashboard and encrypted per user.
VOBIZ_BASE_URL=https://api.vobiz.ai/api
INTEGRATION_ENCRYPTION_KEY=replace-with-a-long-random-secret-different-from-jwt

# Realtime model providers
OPENAI_API_KEY=
GOOGLE_API_KEY=
SARVAM_API_KEY=
